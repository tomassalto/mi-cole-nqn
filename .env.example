# ─── Completar después de la Fase 0 (inspección de red en coleneuquen.com.ar) ───
# URL base de la API de Cole (OneBusAway).
# Probá primero: https://api.coleneuquen.com.ar
COLE_API_BASE=https://api.coleneuquen.com.ar

# API key de OneBusAway. Probá primero "TEST"; si no funciona, la encontrás
# en las llamadas XHR del browser DevTools como parámetro "key=...".
COLE_API_KEY=TEST

# ID de la empresa/agencia en OBA. Miralo en los IDs de las paradas (ej: "NQN_75403" → "NQN").
COLE_AGENCY_ID=NQN

# Puerto local (Railway lo sobreescribe automáticamente)
PORT=3000
