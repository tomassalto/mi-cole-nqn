# ─── API de Visionblo (owa.visionblo.com/api/neuquen/) ───────────────────────
# Token que va en el body de cada request POST.
# Se scrapea automáticamente de app.js al iniciar el server,
# pero podés setearlo manualmente como fallback.
# Mirá server/src/lib/visionblo.ts > getToken() para entender el mecanismo.
VISIONBLO_TOKEN=

# ─── MapTiler ─────────────────────────────────────────────────────────────────
# API key para los tiles del mapa (vector tiles).
# Sacá una gratis en https://cloud.maptiler.com/account/keys/
# Free tier: 100k cargas/mes.
VITE_MAPTILER_KEY=

# ─── Servidor ──────────────────────────────────────────────────────────────────
# Puerto donde corre el servidor Express (default 3001).
PORT=3001

# ─── Push Notifications ───────────────────────────────────────────────────────
# VAPID keys para Web Push. Generalas con:
#   npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_EMAIL=tu@email.com

# ─── Turso / libSQL (opcional, para persistencia en producción) ───────────────
# Si no se setean, usa un archivo local micole.db
# TURSO_DATABASE_URL=libsql://micole-db.turso.io
# TURSO_AUTH_TOKEN=...
